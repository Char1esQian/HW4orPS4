MARKETCHECK_API_KEY=YOUR_MARKETCHECK_API_KEY_HERE
MARKETCHECK_BASE_URL=https://api.marketcheck.com
DEFAULT_STATE=MA

# Optional DB override
DATABASE_URL=sqlite:///./hw4finder.db

# Endpoint mapping overrides (recommended after confirming docs)
# TODO: Replace these with real paths from MarketCheck docs.
MARKETCHECK_SEARCH_ENDPOINT=/TODO_SET_MARKETCHECK_SEARCH_ENDPOINT
MARKETCHECK_HEALTH_ENDPOINT=/TODO_SET_MARKETCHECK_HEALTH_ENDPOINT

# API key delivery mode
MARKETCHECK_API_KEY_IN_QUERY=false
MARKETCHECK_API_KEY_HEADER=x-api-key
MARKETCHECK_API_KEY_QUERY_PARAM=api_key

# Pagination/shape knobs (update after docs/sample response inspection)
MARKETCHECK_PAGE_PARAM=start
MARKETCHECK_PAGE_SIZE_PARAM=rows
MARKETCHECK_PAGE_SIZE=50
MARKETCHECK_MAX_PAGES=200
MARKETCHECK_LISTINGS_KEY=listings
MARKETCHECK_TOTAL_PAGES_KEY=

# Optional FSD mention detection by scraping listing pages.
# `FSD_PAGE_SCAN_ENABLED=true` adds page scans during Refresh.
# The "Scan FSD" button uses timeout/workers below regardless.
FSD_PAGE_SCAN_ENABLED=false
FSD_PAGE_SCAN_TIMEOUT_SECONDS=5
FSD_PAGE_SCAN_WORKERS=6
